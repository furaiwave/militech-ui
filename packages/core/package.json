{
  "name": "@militech/ui",
  "version": "1.0.0",
  "description": "Tactical sci-fi UI component library",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.58.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "storybook": "^10.2.16",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@storybook/react": "^10.2.16",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7"
  }
}
